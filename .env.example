# Root of the local data lake. Inside Airflow containers this is set to the
# container-side mount point (e.g. /opt/airflow/data) — see docker-compose.yml.
DATA_ROOT=./data

# Retention windows (days). Silver must exceed the largest aggregation window
# (the trending mart uses a trailing 7-day average).
BRONZE_RETENTION_DAYS=3
SILVER_RETENTION_DAYS=10

# Optional Slack-compatible webhook for Airflow failure alerts (stage 4).
# ALERT_WEBHOOK_URL=
