# Root of the local data lake. Inside Airflow containers this is set to the
# container-side mount point (e.g. /opt/airflow/data) — see docker-compose.yml.
DATA_ROOT=./data

# Retention windows (days). Silver must exceed the largest aggregation window
# (the trending mart uses a trailing 7-day average).
BRONZE_RETENTION_DAYS=3
SILVER_RETENTION_DAYS=10

# Quality gate hard floor (rows per silver hour). Default set from measured
# data: real hours run ~160k events; 50k catches truncation without
# false-alarming. Lower it if backfilling older, smaller archive eras.
# QUALITY_MIN_ROWS=50000

# Optional Slack-compatible webhook for Airflow failure alerts.
# ALERT_WEBHOOK_URL=

# DuckDB budget for dashboard queries (host-side; keeps Streamlit from
# inheriting the 2GB pipeline default on a small machine).
# DASHBOARD_DUCKDB_MEMORY_LIMIT=256MB
